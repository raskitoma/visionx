# Source Databases (Format: [!]user:pass@host:port/dbname|LineName,...)
# The '!' prefix indicates using current host time instead of source DB time.
SOURCE_DBS="!user:password@host:port/dbname|LineName"

# Target Database (Format: user:password@host:port/dbname)
TARGET_DB="user:password@host:port/dbname"

# Timezone
TZ="America/New_York"

# Records Limit per sync
RECORDS_LIMIT=100

# InfluxDB Configuration
INFLUX_HOST="http://localhost:8086"
INFLUX_TOKEN="YOUR_INFLUX_TOKEN"
INFLUX_ORG="YOUR_ORG"
INFLUX_BUCKET="YOUR_BUCKET"
